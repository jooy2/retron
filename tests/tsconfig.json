{
  "compilerOptions": {
    "target": "esnext",
    "module": "Preserve",
    "moduleDetection": "force",
    "noImplicitAny": false,
    "allowSyntheticDefaultImports": true,
    "resolveJsonModule": true,
    "esModuleInterop": true,
    "strict": true,
    "skipLibCheck": true,
    "noEmit": true,
    "types": ["node"],
    "lib": ["esnext", "dom"]
  },
  "include": ["**/*.ts"]
}
